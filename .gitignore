# Ignore all files beginning with a dot (.)
.*
# except for git files
!.devcontainer/
!.github/
!.cursor/
!.vscode/
!.editorconfig
!.gitattributes
!.gitignore
!.spelling
!.env.example
!Tests/**/.template.ps1

# Ignore configuration files
.env
.vscode/launch.json

# Ignore Release directory generated by local builds
Release/
# Module-local generated help output path (JiraPS uses JiraPS/en-US/)
JiraAgilePS/en-US/
Test*.xml
PSScriptAnalyzerSettings.psd1

# Ignore backup files from Pester migration
*.bak

#######
# Excerpts from https://www.gitignore.io
#######

### OSX ###
._*
.DS_Store
.AppleDouble
.LSOverride

### Windows ###
# Windows image file caches
Desktop.ini
Thumbs.db
ehthumbs.db
